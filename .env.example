PORT=3000

# Banco de dados
DB_HOST=localhost
DB_PORT=3306
DB_USER=SEU_USUARIO_DB
DB_PASS=SUA_SENHA_DB
DB_NAME=SEU_BANCO_DB

# Segurança — gere um valor único e forte (ex: openssl rand -base64 48)
JWT_SECRET=GERE_UM_VALOR_SECRETO_FORTE_AQUI

# SMTP para email de recuperação de senha
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app_google

# Token de segurança do webhook Hotmart (configurar em: Hotmart > Ferramentas > Webhooks > Hottok)
HOTMART_HOTTOK=SEU_TOKEN_HOTMART_AQUI

# URL pública da aplicação
APP_URL=https://panificapro-erp.onrender.com

# Origens permitidas pelo CORS (separadas por vírgula)
ALLOWED_ORIGINS=https://panificapro-erp.onrender.com
